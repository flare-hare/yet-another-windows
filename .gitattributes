# Нормализация текстовых файлов: LF в репозитории
* text=auto eol=lf

# Бинарные файлы — не трогать (без нормализации переносов/кодировки).
# Иначе git может «сломать» их (как ломался .xlsx).
*.woff2 binary
*.woff  binary
*.ttf   binary
*.otf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.avif  binary
*.ico   binary
*.xlsx  binary
*.pdf   binary
